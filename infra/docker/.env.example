# === Minutare Med — Environment Variables ===

# --- Database ---
POSTGRES_USER=minutare
POSTGRES_PASSWORD=minutare_secret_change_me
POSTGRES_DB=minutare_med
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://minutare:minutare_secret_change_me@db:5432/minutare_med

# --- Telegram ---
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=random_secret_for_webhook_validation

# --- AI / LLM ---
# Configure at least ONE provider for LLM responses (otherwise uses template fallback):
# OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=your-gemini-key-here
# LLM_MODEL=  # override: gpt-4o-mini, claude-sonnet-4-20250514, gemini-2.5-flash

# --- Embeddings ---
# For vector RAG, configure OpenAI or Gemini key above.
# Without an API key, the system uses text-based keyword search (functional but less precise).
EMBEDDING_PROVIDER=gemini

# --- RAG ---
RAG_CONFIDENCE_THRESHOLD=0.75
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-me-to-a-random-string
CORS_ORIGINS=["http://localhost:3000"]
