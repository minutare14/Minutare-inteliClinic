# InteliClinic — Variáveis de Ambiente por Deploy
# =================================================
# IMPORTANTE: Copie este arquivo para .env e preencha com os valores REAIS desta clínica.
# NUNCA commite o .env no repositório — contém credenciais sensíveis.
#
# Cada clínica tem seu próprio .env com valores únicos.
# Regra: Nova clínica = novo deploy, novo .env. Não é permitido compartilhar .env entre clínicas.

# ------------------------------------------------------------------
# IDENTIDADE DA CLÍNICA (CLINIC_*)
# Estes valores identificam ESTA instância do InteliClinic.
# ------------------------------------------------------------------
CLINIC_ID=clinica_exemplo_sp
CLINIC_NAME=Clínica Exemplo Saúde
CLINIC_SHORT_NAME=Clínica Exemplo
CLINIC_CNPJ=00.000.000/0001-00
CLINIC_DOMAIN=bot.clinicaexemplo.com.br
CLINIC_PHONE=(11) 0000-0000
CLINIC_CITY=São Paulo
CLINIC_STATE=SP
CLINIC_TIMEZONE=America/Sao_Paulo

# ------------------------------------------------------------------
# FEATURES HABILITADAS (por clínica)
# ------------------------------------------------------------------
CLINIC_FEATURE_SCHEDULING=true
CLINIC_FEATURE_INSURANCE_QUERY=true
CLINIC_FEATURE_FINANCIAL=false
CLINIC_FEATURE_GLOSA_DETECTION=false
CLINIC_FEATURE_VOICE=false
CLINIC_FEATURE_GRAPHRAG=false

# ------------------------------------------------------------------
# BRANDING DO CHATBOT
# ------------------------------------------------------------------
CLINIC_CHATBOT_NAME=Assistente
CLINIC_CHATBOT_GREETING=Olá! Sou o assistente virtual da {clinic_name}. Como posso ajudá-lo?
CLINIC_PRIMARY_COLOR=#0066CC

# ------------------------------------------------------------------
# HORÁRIOS DE ATENDIMENTO
# ------------------------------------------------------------------
CLINIC_BUSINESS_HOURS_START=08:00
CLINIC_BUSINESS_HOURS_END=18:00
CLINIC_BUSINESS_DAYS=[1,2,3,4,5]

# ------------------------------------------------------------------
# CONVÊNIOS ACEITOS
# ------------------------------------------------------------------
CLINIC_ACCEPTED_INSURANCES=["Unimed", "Bradesco Saúde", "Amil"]
CLINIC_ACCEPTS_PRIVATE=true

# ------------------------------------------------------------------
# BANCO DE DADOS (desta VPS — exclusivo desta clínica)
# ------------------------------------------------------------------
POSTGRES_USER=inteliclinic
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=inteliclinic_prod
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://inteliclinic:CHANGE_ME_strong_password_here@db:5432/inteliclinic_prod

# ------------------------------------------------------------------
# TELEGRAM (bot exclusivo desta clínica)
# ------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=SEU_TOKEN_AQUI
TELEGRAM_WEBHOOK_URL=https://bot.clinicaexemplo.com.br/api/v1/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=string_aleatoria_32_caracteres_aqui

# ------------------------------------------------------------------
# LLM / AI (configuração desta clínica)
# Configure pelo menos um provedor de LLM.
# ------------------------------------------------------------------
CLINIC_LLM_PROVIDER=openai
CLINIC_LLM_MODEL=gpt-4o-mini
CLINIC_MIN_CONFIDENCE=0.65
CLINIC_MAX_TURNS=20

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (alternativa)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (alternativa)
# GEMINI_API_KEY=...

# ------------------------------------------------------------------
# RAG / VECTOR STORE (Qdrant desta VPS)
# Cada clínica usa sua própria collection: inteliclinic_{CLINIC_ID}
# ------------------------------------------------------------------
CLINIC_QDRANT_URL=http://qdrant:6333
CLINIC_RAG_TOP_K=5
CLINIC_RAG_MIN_SCORE=0.70
CLINIC_RAG_CHUNK_SIZE=800
CLINIC_RAG_CHUNKER_STRATEGY=semantic

# Embeddings (usa o mesmo provedor do LLM por padrão)
EMBEDDING_PROVIDER=openai

# ------------------------------------------------------------------
# APLICAÇÃO
# ------------------------------------------------------------------
APP_ENV=production
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=CHANGE_ME_random_secret_key_here
CORS_ORIGINS=["https://painel.clinicaexemplo.com.br"]

# ------------------------------------------------------------------
# AVALIAÇÃO (opcional — para rodar scripts/evaluate_rag.py)
# ------------------------------------------------------------------
# EVAL_LLM_MODEL=gpt-4o-mini
# EVAL_METRICS=faithfulness,answer_relevancy,context_recall,context_precision
