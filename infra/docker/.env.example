# .env.example — Desenvolvimento Local
# ======================================
# Este arquivo é para rodar localmente com infra/docker/docker-compose.yml
# Para produção, use o .env.example na raiz do projeto.
#
# Uso:
#   cd infra/docker
#   cp .env.example .env
#   docker compose up --build

# Banco
POSTGRES_USER=minutare
POSTGRES_PASSWORD=minutare
POSTGRES_DB=minutare_dev

# Aplicação
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG
APP_SECRET_KEY=dev-secret-key-nao-usar-em-producao
CORS_ORIGINS=["http://localhost:3000"]

# LLM (pelo menos um obrigatório para funcionar)
OPENAI_API_KEY=sk-...
EMBEDDING_PROVIDER=openai

# Telegram (opcional em dev)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=dev-secret

# RAG
RAG_CONFIDENCE_THRESHOLD=0.75
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100

# Clínica
CLINIC_ID=dev_local
CLINIC_NAME=Clínica Dev Local
