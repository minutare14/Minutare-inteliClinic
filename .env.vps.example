# ============================================================
# .env.vps.example — Minutare InteliClinic
# Arquivo modelo para deploy na VPS via Dokploy + Docker Compose
# ============================================================
# INSTRUÇÕES:
#   1. Copie para .env:  cp .env.vps.example .env
#   2. Preencha TODOS os campos marcados com [OBRIGATÓRIO]
#   3. NUNCA commite o .env — ele contém credenciais reais
#   4. NEXT_PUBLIC_API_URL deve estar definida ANTES do build
# ============================================================


# ------------------------------------------------------------
# IDENTIDADE DO DEPLOY
# ------------------------------------------------------------

# Nome interno do projeto — usado em nomes de containers e routers Traefik
# Somente letras minúsculas, números e hífens. Ex: clinica-saude-sp
COMPOSE_PROJECT_NAME=minutare                            # [OBRIGATÓRIO]

# Domínio público do painel (frontend Next.js)
FRONTEND_DOMAIN=painel.suaclinica.com.br                 # [OBRIGATÓRIO]

# Domínio público da API (backend FastAPI)
API_DOMAIN=api.suaclinica.com.br                         # [OBRIGATÓRIO]


# ------------------------------------------------------------
# BANCO DE DADOS — PostgreSQL 16 + pgvector
# ------------------------------------------------------------

POSTGRES_USER=minutare                                   # [OBRIGATÓRIO]
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI            # [OBRIGATÓRIO] use: openssl rand -hex 32
POSTGRES_DB=minutare_prod                                # [OBRIGATÓRIO]

# DATABASE_URL é montada automaticamente pelo docker-compose a partir das
# variáveis acima. Defina apenas para sobrescrever (banco externo gerenciado).
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db


# ------------------------------------------------------------
# APLICAÇÃO — API FastAPI
# ------------------------------------------------------------

APP_ENV=production                                       # [OBRIGATÓRIO] production | development
APP_DEBUG=false
APP_LOG_LEVEL=INFO                                       # DEBUG | INFO | WARNING | ERROR

# Chave de assinatura interna — gerada uma vez por instância
APP_SECRET_KEY=GERE_COM_openssl_rand_hex_32              # [OBRIGATÓRIO]

# Origens CORS permitidas — liste os domínios reais separados por vírgula
# Formato JSON array: ["https://painel.suaclinica.com.br"]
CORS_ORIGINS=["https://painel.suaclinica.com.br"]        # [OBRIGATÓRIO]

# Workers Uvicorn — mantenha 1 para async/SQLAlchemy (evita race conditions)
UVICORN_WORKERS=1


# ------------------------------------------------------------
# FRONTEND — Next.js
# ------------------------------------------------------------

# URL pública da API — VARIÁVEL DE BUILD (baked no bundle Next.js)
# DEVE ser o endereço acessível pelo navegador do usuário final.
# Precisa estar definida ANTES de `docker compose build`.
NEXT_PUBLIC_API_URL=https://api.suaclinica.com.br        # [OBRIGATÓRIO]


# ------------------------------------------------------------
# INTELIGÊNCIA ARTIFICIAL / LLM
# Forneça pelo menos um provider
# ------------------------------------------------------------

# OpenAI (recomendado para produção)
OPENAI_API_KEY=sk-...                                    # [OBRIGATÓRIO se usar OpenAI]

# Anthropic (alternativa ao OpenAI)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (alternativa)
# GEMINI_API_KEY=AIzaSy...

# Provider usado para embeddings
EMBEDDING_PROVIDER=openai                                # openai | anthropic | local

# Modelo LLM — deixe vazio para usar o default do provider
LLM_MODEL=


# ------------------------------------------------------------
# TELEGRAM BOT
# ------------------------------------------------------------

TELEGRAM_BOT_TOKEN=                                      # [OBRIGATÓRIO para canal Telegram]
TELEGRAM_WEBHOOK_URL=https://api.suaclinica.com.br/api/v1/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=GERE_COM_openssl_rand_hex_32     # [OBRIGATÓRIO] mínimo 32 chars


# ------------------------------------------------------------
# RAG — Retrieval-Augmented Generation
# ------------------------------------------------------------

# QDRANT_URL é injetado automaticamente no docker-compose (http://qdrant:6333)
# Defina somente se usar Qdrant externo:
# QDRANT_URL=http://qdrant:6333

RAG_CONFIDENCE_THRESHOLD=0.75
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100


# ------------------------------------------------------------
# IDENTIDADE DA CLÍNICA
# ------------------------------------------------------------

CLINIC_ID=clinica_exemplo_sp                             # [OBRIGATÓRIO] slug único por clínica
CLINIC_NAME=Clínica Exemplo Saúde
CLINIC_SHORT_NAME=Clínica Exemplo
CLINIC_CNPJ=00.000.000/0001-00
CLINIC_DOMAIN=suaclinica.com.br
CLINIC_PHONE=(11) 0000-0000
CLINIC_CITY=São Paulo
CLINIC_STATE=SP
CLINIC_TIMEZONE=America/Sao_Paulo


# ------------------------------------------------------------
# FEATURES — habilitar/desabilitar por clínica
# ------------------------------------------------------------

CLINIC_FEATURE_SCHEDULING=true
CLINIC_FEATURE_INSURANCE_QUERY=true
CLINIC_FEATURE_FINANCIAL=false
CLINIC_FEATURE_GLOSA_DETECTION=false
CLINIC_FEATURE_VOICE=false
CLINIC_FEATURE_GRAPHRAG=false


# ------------------------------------------------------------
# BRANDING DO CHATBOT
# ------------------------------------------------------------

CLINIC_CHATBOT_NAME=Assistente
CLINIC_CHATBOT_GREETING=Olá! Sou o assistente virtual da {clinic_name}. Como posso ajudá-lo?
CLINIC_PRIMARY_COLOR=#0066CC


# ------------------------------------------------------------
# HORÁRIO DE FUNCIONAMENTO
# ------------------------------------------------------------

CLINIC_BUSINESS_HOURS_START=08:00
CLINIC_BUSINESS_HOURS_END=18:00
CLINIC_BUSINESS_DAYS=[1,2,3,4,5]                        # 1=seg ... 6=sab, 7=dom


# ------------------------------------------------------------
# CONVÊNIOS ACEITOS
# ------------------------------------------------------------

CLINIC_ACCEPTED_INSURANCES=["Unimed","Bradesco Saúde","Amil"]
CLINIC_ACCEPTS_PRIVATE=true
