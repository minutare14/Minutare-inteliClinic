# ============================================================
# .env.vps.example — IntelliClinic
# Deploy VPS via Dokploy + Docker Compose
# ============================================================
# INSTRUÇÕES:
#   1. Copie para .env:  cp .env.vps.example .env
#   2. Preencha os campos marcados com [PREENCHER]
#   3. NUNCA commite o .env — ele contém credenciais reais
#   4. NEXT_PUBLIC_API_URL deve estar definida ANTES do build
# ============================================================


# ------------------------------------------------------------
# IDENTIDADE DO DEPLOY
# ------------------------------------------------------------

# Nome interno — usado em nomes de containers e routers Traefik
COMPOSE_PROJECT_NAME=climesa

# Domínio público do painel (frontend Next.js)
FRONTEND_DOMAIN=inteliclinic.minutarecore.space

# Domínio público da API (backend FastAPI)
API_DOMAIN=api.inteliclinic.minutarecore.space


# ------------------------------------------------------------
# BANCO DE DADOS — PostgreSQL 16 + pgvector
# ------------------------------------------------------------

POSTGRES_USER=minutare
POSTGRES_PASSWORD=ASD14200
POSTGRES_DB=minutare_prod

# DATABASE_URL é montada automaticamente pelo docker-compose.
# Só defina se usar banco externo gerenciado:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db


# ------------------------------------------------------------
# APLICAÇÃO — API FastAPI
# ------------------------------------------------------------

APP_ENV=production
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# Chave de assinatura interna
# ATENÇÃO: em produção real gere com: openssl rand -hex 32
APP_SECRET_KEY=ASD14200

# Origens CORS permitidas — formato JSON array
CORS_ORIGINS=["https://inteliclinic.minutarecore.space"]

# Workers Uvicorn — manter 1 para async/SQLAlchemy
UVICORN_WORKERS=1
BOOTSTRAP_SEED_ON_STARTUP=false
BOOTSTRAP_SEED_WITH_EMBEDDINGS=false
BOOTSTRAP_REGISTER_TELEGRAM_WEBHOOK_ON_STARTUP=true

# ------------------------------------------------------------
# AUTH — Default admin user (seeded on first startup)
# ------------------------------------------------------------
ADMIN_DEFAULT_EMAIL=admin@climesa.com
ADMIN_DEFAULT_PASSWORD=change-me-on-first-login


# ------------------------------------------------------------
# FRONTEND — Next.js
# ------------------------------------------------------------

# URL pública da API — VARIÁVEL DE BUILD (baked no bundle Next.js)
# DEVE estar definida ANTES de `docker compose build`
NEXT_PUBLIC_API_URL=https://api.inteliclinic.minutarecore.space


# ------------------------------------------------------------
# INTELIGÊNCIA ARTIFICIAL / LLM — Groq
# ------------------------------------------------------------

# Provider explícito (groq | openai | anthropic | gemini)
# Se vazio, auto-detecta pela primeira chave disponível: Groq → OpenAI → Anthropic → Gemini
LLM_PROVIDER=groq

# Groq API Key — obter em https://console.groq.com/keys
GROQ_API_KEY=[PREENCHER]                            # [OBRIGATÓRIO]

# Modelo Groq escolhido: llama-3.3-70b-versatile
# Outros disponíveis: mixtral-8x7b-32768, llama3-8b-8192, gemma2-9b-it
LLM_MODEL=llama-3.3-70b-versatile

# Providers alternativos (descomentados se migrar de Groq)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIzaSy...

# ─── Embeddings RAG (SEPARADO do LLM provider) ────────────────────────────────
# IMPORTANTE: Groq NÃO suporta embeddings. Configure EMBEDDING_PROVIDER
# separado do LLM_PROVIDER.
#
# Opção A — Local/gratuito (RECOMENDADO, sem API key)
#   Usa sentence-transformers. Baixa o modelo no primeiro uso.
#   Modelo: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (384 dims, PT-BR)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384
#
# Opção B — OpenAI (pago, melhor qualidade, 1536 dims)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_DIM=1536
# OPENAI_API_KEY=sk-...
#
# Opção C — Gemini (free tier, 768 dims)
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_DIM=768
# GEMINI_API_KEY=AIzaSy...


# ------------------------------------------------------------
# TELEGRAM BOT
# ------------------------------------------------------------

TELEGRAM_BOT_TOKEN=[PREENCHER]                      # [OBRIGATÓRIO] — token do BotFather

# URL do webhook — OPCIONAL se API_DOMAIN estiver definido acima.
# O sistema deriva automaticamente: https://{API_DOMAIN}/api/v1/telegram/webhook
# Defina explicitamente apenas se usar domínio diferente do API_DOMAIN.
# TELEGRAM_WEBHOOK_URL=https://api.inteliclinic.minutarecore.space/api/v1/telegram/webhook

# Secret para validar que as requisições vêm do Telegram
# ATENÇÃO: em produção real gere com: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=ASD14200


# ------------------------------------------------------------
# RAG — Retrieval-Augmented Generation
# ------------------------------------------------------------

# QDRANT_URL é injetado automaticamente no docker-compose (http://qdrant:6333)
# Só defina se usar Qdrant externo:
# QDRANT_URL=http://qdrant:6333

RAG_CONFIDENCE_THRESHOLD=0.75
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100
RAG_DOCUMENT_GRADING_ENABLED=true
RAG_DOCUMENT_GRADING_MIN_SCORE=0.58
RAG_DOCUMENT_GRADING_MIN_APPROVED_CHUNKS=1
RAG_QUERY_REWRITE_ENABLED=true
RAG_QUERY_REWRITE_MAX_RETRIES=1
RAG_RERANKER_ENABLED=false
RAG_RERANKER_TOP_K_INITIAL=20
RAG_RERANKER_TOP_K_FINAL=5
LANGGRAPH_RUNTIME_ENABLED=true
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=inteliclinic-runtime
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com


# ------------------------------------------------------------
# Pinecone Vector Store
# ------------------------------------------------------------

PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX=inteliclinic-rag
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1


# ------------------------------------------------------------
# IDENTIDADE DA CLÍNICA
# ------------------------------------------------------------

CLINIC_ID=climesa
CLINIC_NAME=climesa
CLINIC_SHORT_NAME=climesa
CLINIC_CNPJ=00.000.000/0001-00
CLINIC_DOMAIN=minutarecore.space
CLINIC_PHONE=(00) 0000-0000
CLINIC_CITY=São Paulo
CLINIC_STATE=SP
CLINIC_TIMEZONE=America/Sao_Paulo


# ------------------------------------------------------------
# FEATURES — habilitar/desabilitar por clínica
# ------------------------------------------------------------

CLINIC_FEATURE_SCHEDULING=true
CLINIC_FEATURE_INSURANCE_QUERY=true
CLINIC_FEATURE_FINANCIAL=false
CLINIC_FEATURE_GLOSA_DETECTION=false
CLINIC_FEATURE_VOICE=false
CLINIC_FEATURE_GRAPHRAG=false


# ------------------------------------------------------------
# BRANDING DO CHATBOT
# ------------------------------------------------------------

CLINIC_CHATBOT_NAME=Assistente
CLINIC_CHATBOT_GREETING=Olá! Sou o assistente virtual da {clinic_name}. Como posso ajudá-lo?
CLINIC_PRIMARY_COLOR=#0066CC


# ------------------------------------------------------------
# HORÁRIO DE FUNCIONAMENTO
# ------------------------------------------------------------

CLINIC_BUSINESS_HOURS_START=08:00
CLINIC_BUSINESS_HOURS_END=18:00
CLINIC_BUSINESS_DAYS=[1,2,3,4,5]                    # 1=seg ... 6=sab, 7=dom


# ------------------------------------------------------------
# CONVÊNIOS ACEITOS
# ------------------------------------------------------------

CLINIC_ACCEPTED_INSURANCES=["Unimed","Bradesco Saúde","Amil"]
CLINIC_ACCEPTS_PRIVATE=true


# ------------------------------------------------------------
# AUTH / JWT
# ------------------------------------------------------------

# JWT signing key — OBRIGATÓRIO em produção
# Gerar: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=[PREENCHER]                            # [OBRIGATÓRIO]
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Usuário admin padrão — seed no primeiro startup. Trocar via Admin UI.
ADMIN_DEFAULT_EMAIL=admin@clinic.local
ADMIN_DEFAULT_PASSWORD=[PREENCHER]                    # [OBRIGATÓRIO]


# ------------------------------------------------------------
# GOOGLE CALENDAR (opcional)
# ------------------------------------------------------------
# Obter em Google Cloud Console → APIs & Services → Credentials
# Tipo: OAuth 2.0 Client ID (Web application)
# Authorized redirect URI: https://{API_DOMAIN}/api/v1/google/callback

# GOOGLE_CLIENT_ID=[PREENCHER]
# GOOGLE_CLIENT_SECRET=[PREENCHER]
# GOOGLE_REDIRECT_URI=https://api.inteliclinic.minutarecore.space/api/v1/google/callback


# ------------------------------------------------------------
# WORKERS (opcional)
# ------------------------------------------------------------

# Intervalo do worker de follow-ups em segundos (padrão: 300 = 5 min)
# FOLLOWUP_WORKER_INTERVAL_SECONDS=300
